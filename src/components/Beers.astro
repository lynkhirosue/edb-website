---
import '../styles/beers.css';
import '@phosphor-icons/web/regular';
import { CATALOG_URL, isAllowedBeerImageURL, isAllowedLocalBeerImagePath } from '../config/catalog';
import { loadBeers, loadCatalog } from '../utils/data-loader';
import { buildBeerDisplayItems } from '../utils/catalog-display';
import { DEFAULT_BEER_IMAGE_PATH } from '../utils/catalog-mapper';
import { safeJsonStringify } from '../utils/json-serialization';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
const createdBeers = await loadBeers();
const rawCatalog = await loadCatalog();
const displayBeers = buildBeerDisplayItems(createdBeers, rawCatalog);
const catalogRuntimeMeta = {
  url: CATALOG_URL,
  generatedAt: rawCatalog?.generatedAt ?? null,
  pollIntervalMs: 120000
};

function resolvePublicBeerImage(path?: string): string | undefined {
  if (!path) {
    return undefined;
  }

  const normalizedWebPath = path.startsWith('/') ? path : `/${path}`;
  return isAllowedLocalBeerImagePath(normalizedWebPath) ? normalizedWebPath : undefined;
}

/**
 * Les images publiées par BreweryManager arrivent désormais sous forme d'URL
 * absolue (https://assets.lecoledubelier.beer/images/<slug>.webp). On les
 * renvoie telles quelles pour laisser le navigateur les charger depuis R2/CDN.
 */
function resolveRemoteBeerImage(path?: string): string | undefined {
  if (!path) return undefined;
  return isAllowedBeerImageURL(path) ? path : undefined;
}

const beersForUi = displayBeers.map((beer) => ({
  ...beer,
  cardImagePath:
    resolveRemoteBeerImage(beer.image) ??
    resolvePublicBeerImage(beer.image) ??
    DEFAULT_BEER_IMAGE_PATH,
  detailImage:
    resolveRemoteBeerImage(beer.image) ??
    resolvePublicBeerImage(beer.image) ??
    DEFAULT_BEER_IMAGE_PATH
}));

const familyPublicationCounts = beersForUi.reduce((counts, beer) => {
  counts.set(beer.groupingKey, (counts.get(beer.groupingKey) ?? 0) + 1);
  return counts;
}, new Map<string, number>());

const carouselBeers = beersForUi.map((beer) => ({
  ...beer,
  familyPublicationCount: familyPublicationCounts.get(beer.groupingKey) ?? 1
}));

const beersForScript = beersForUi.map(({ cardImagePath, ...beer }) => ({
  ...beer,
  detailImage: beer.detailImage ?? cardImagePath
}));

const beersJson = safeJsonStringify(beersForScript);
const catalogRuntimeMetaJson = safeJsonStringify(catalogRuntimeMeta);
---

<section id="beers" class={`beers-section ${className}`} aria-labelledby="beers-title">
  <div class="beers-container">
    <div class="beers-header reveal">
      <h2 id="beers-title" class="beers-title">Nos créations</h2>
      <p class="lead">Recettes vivantes, profils aromatiques assumés, disponibilité en temps réel.</p>
    </div>

    <div class="beer-quiz-shell reveal" aria-labelledby="beer-quiz-shell-title">
      <h3 id="beer-quiz-shell-title">Trouve ta bière en 30 secondes</h3>
      <p>Le questionnaire est masqué par défaut pour garder une page épurée.</p>
      <button
        id="quiz-open-btn"
        type="button"
        class="quiz-open-btn"
        data-analytics="cta_click"
        data-analytics-label="quiz-open"
      >
        Lancer le questionnaire
      </button>
    </div>

    <div class="beer-carousel reveal" data-beer-carousel>
      <p id="beer-carousel-status" class="visually-hidden" aria-live="polite">
        1 sur {carouselBeers.length}
      </p>

      <div class="beer-carousel-stage">
        <button
          class="beer-carousel-button beer-carousel-previous"
          type="button"
          data-carousel-previous
          aria-label="Afficher les bières précédentes"
          aria-controls="beer-carousel-viewport"
          disabled
        >
          <i class="ph ph-caret-left" aria-hidden="true"></i>
        </button>

        <div
          id="beer-carousel-viewport"
          class="beer-carousel-viewport"
          data-carousel-viewport
          role="region"
          aria-roledescription="carrousel"
          aria-label="Bières de la brasserie"
          aria-describedby="beer-carousel-status"
          tabindex="0"
        >
          <div class="beer-carousel-track" data-carousel-track>
            {carouselBeers.map((beer, index) => (
              <article
                id={beer.id}
                class="beer-card"
                data-beer-id={beer.id}
                data-carousel-item
                role="group"
                aria-roledescription="diapositive"
                aria-label={`${index + 1} sur ${carouselBeers.length} : ${beer.name}`}
              >
              <div class="beer-image">
                <img
                  src={beer.cardImagePath}
                  alt={beer.type ? `${beer.name}, ${beer.type}` : beer.name}
                  loading="lazy"
                  width="800"
                  height="600"
                />
              </div>

              <div class="beer-content">
                <div class="beer-meta-line">
                  {beer.type && <span class="beer-type">{beer.type}</span>}
                  <span class={`beer-availability status-${beer.statusKind}`}>{beer.statusLabel}</span>
                </div>

                <h3 class="beer-name">{beer.name}</h3>
                {beer.familyPublicationCount > 1 && (
                  <p class="beer-family-note">{beer.familyPublicationCount} versions publiées</p>
                )}
                {beer.recipeRevision && <p class="beer-revision">Recette V{beer.recipeRevision}</p>}
                {beer.description && <p class="beer-description">{beer.description}</p>}

                {beer.lifecycleBadges.length > 1 && (
                  <div class="beer-lifecycle-badges" aria-label="États actifs">
                    {beer.lifecycleBadges.map((badge) => (
                      <span class={`beer-lifecycle-badge status-${badge.kind}`}>{badge.label}</span>
                    ))}
                  </div>
                )}

                {beer.statusDetail && (
                  <p class="beer-catalog-note">{beer.statusDetail}</p>
                )}

                {beer.packagings.length > 0 && (
                  <ul class="beer-packagings" aria-label="Formats disponibles">
                    {beer.packagings.map((packaging) => (
                      <li>
                        <span>{packaging.label}</span>
                        <strong>{packaging.priceLabel}</strong>
                      </li>
                    ))}
                  </ul>
                )}

                {beer.imageIsTemporary && beer.imageAttribution && (
                  <p class="beer-image-attribution">Image temporaire · {beer.imageAttribution}</p>
                )}

                {beer.tags.length > 0 && <div class="beer-tags">
                  {beer.tags.map((tag) => (
                    <span class="beer-tag">{tag}</span>
                  ))}
                </div>}

                <div class="beer-footer">
                  {beer.abv && <span class="beer-abv">{beer.abv}</span>}
                  <a
                    href={`/bieres/${beer.id}`}
                    class="detail-btn js-open-beer-details"
                    data-beer-id={beer.id}
                    data-analytics="beer_detail_open"
                    data-analytics-label={beer.id}
                  >
                    Voir la fiche
                  </a>
                </div>
              </div>
              </article>
            ))}
          </div>
        </div>

        <button
          class="beer-carousel-button beer-carousel-next"
          type="button"
          data-carousel-next
          aria-label="Afficher les bières suivantes"
          aria-controls="beer-carousel-viewport"
        >
          <i class="ph ph-caret-right" aria-hidden="true"></i>
        </button>
      </div>

      <div class="beer-carousel-pagination" data-carousel-pagination aria-label="Pages du carrousel">
        {carouselBeers.map((_, index) => (
          <button
            class="beer-carousel-dot"
            type="button"
            data-carousel-dot
            data-page-index={index}
            aria-label={`Afficher la page ${index + 1}`}
            aria-controls="beer-carousel-viewport"
            aria-current={index === 0 ? 'true' : undefined}
          ></button>
        ))}
      </div>
    </div>
  </div>

  <div id="quiz-modal-overlay" class="quiz-modal-overlay" hidden></div>
  <div
    id="quiz-modal"
    class="quiz-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="beer-quiz-modal-title"
    aria-describedby="beer-quiz-modal-description"
    hidden
  >
    <div class="quiz-modal-content">
      <button id="quiz-close-btn" type="button" class="quiz-modal-close" aria-label="Fermer le questionnaire">&times;</button>

      <h3 id="beer-quiz-modal-title">Trouve ta bière en 5 questions</h3>
      <p id="beer-quiz-modal-description" class="quiz-modal-description">
        Réponds aux questions pour obtenir une recommandation parmi les bières affichées.
      </p>
      <form id="beer-quiz-form" class="beer-quiz-form">
        <fieldset>
          <legend>Intensité recherchée</legend>
          <label><input type="radio" name="intensity" value="light" /> Légère</label>
          <label><input type="radio" name="intensity" value="balanced" /> Équilibrée</label>
          <label><input type="radio" name="intensity" value="bold" /> Puissante</label>
        </fieldset>

        <fieldset>
          <legend>Dominante aromatique</legend>
          <label><input type="radio" name="aroma" value="hoppy" /> Houblonnée</label>
          <label><input type="radio" name="aroma" value="malty" /> Maltée</label>
          <label><input type="radio" name="aroma" value="spicy" /> Épicée</label>
          <label><input type="radio" name="aroma" value="fruity" /> Fruitée</label>
        </fieldset>

        <fieldset>
          <legend>Moment de dégustation</legend>
          <label><input type="radio" name="occasion" value="apero" /> Apéro</label>
          <label><input type="radio" name="occasion" value="meal" /> À table</label>
          <label><input type="radio" name="occasion" value="cozy" /> Soirée cocooning</label>
        </fieldset>

        <fieldset>
          <legend>Finale préférée</legend>
          <label><input type="radio" name="finish" value="dry" /> Sèche</label>
          <label><input type="radio" name="finish" value="round" /> Ronde</label>
        </fieldset>

        <fieldset>
          <legend>Niveau de surprise</legend>
          <label><input type="radio" name="adventure" value="classic" /> Classique rassurant</label>
          <label><input type="radio" name="adventure" value="surprise" /> Profil audacieux</label>
        </fieldset>

        <button type="submit" class="quiz-submit" data-analytics="cta_click" data-analytics-label="quiz-submit">
          Voir ma recommandation
        </button>
      </form>

      <aside id="quiz-result" class="quiz-result" hidden aria-live="polite">
        <h4 id="quiz-result-title"></h4>
        <ul id="quiz-result-reasons"></ul>
        <button id="quiz-result-button" type="button" class="quiz-detail-btn" hidden>
          Ouvrir la fiche détaillée
        </button>
      </aside>
    </div>
  </div>

  <div id="beer-modal-overlay" class="beer-modal-overlay" hidden></div>
  <div
    id="beer-modal"
    class="beer-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="beer-modal-title"
    aria-describedby="beer-modal-description"
    hidden
  >
    <div class="beer-modal-content">
      <button id="beer-modal-close" type="button" class="beer-modal-close" aria-label="Fermer la fiche">&times;</button>

      <div class="beer-modal-visual">
        <img id="beer-modal-image" src="" alt="" loading="lazy" />
      </div>

      <div class="beer-modal-body">
        <p id="beer-modal-type" class="beer-modal-type"></p>
        <h3 id="beer-modal-title"></h3>
        <p id="beer-modal-description"></p>
        <p class="beer-modal-availability-label">
          Statut: <strong id="beer-modal-availability"></strong>
        </p>
        <p id="beer-modal-status-detail" class="beer-modal-status-detail" hidden></p>
        <div id="beer-modal-lifecycles" class="beer-modal-lifecycles" hidden></div>

        <div class="beer-modal-columns">
          <section>
            <h4>Profil</h4>
            <ul id="beer-modal-profile"></ul>
          </section>
          <section>
            <h4>Accords</h4>
            <ul id="beer-modal-pairings"></ul>
          </section>
          <section id="beer-modal-packagings-section" hidden>
            <h4>Formats</h4>
            <ul id="beer-modal-packagings"></ul>
          </section>
        </div>
      </div>
    </div>
  </div>
</section>

<script id="beers-data" type="application/json" set:html={beersJson}></script>
<script id="catalog-runtime-meta" type="application/json" set:html={catalogRuntimeMetaJson}></script>
<script>
  import '../scripts/beers-page.ts';
  import '../scripts/catalog-update-notifier.ts';
</script>
