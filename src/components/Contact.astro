---
import '../styles/contact.css';
import {
  CONTACT_FORM_CAPTCHA_ENABLED,
  CONTACT_FORM_ENDPOINT_TOKEN,
  CONTACT_FORM_PROVIDER,
  CONTACT_FORM_REDIRECT_URL
} from '../config/contact';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
const formPageUrl = Astro.url.href;
---

<section id="contact" class={`contact-section ${className}`} aria-labelledby="contact-title">
  <div class="contact-container reveal">
    <h2 id="contact-title" class="contact-title">Nous contacter</h2>
    <p class="lead contact-lead">
      Inscris-toi pour recevoir les prochaines sorties.
    </p>

    <form
      id="alert-form"
      class="alert-form"
      method="POST"
      action="/#contact"
      data-analytics="alert_signup"
      data-analytics-label="contact-section"
      data-provider={CONTACT_FORM_PROVIDER}
      data-endpoint-token={CONTACT_FORM_ENDPOINT_TOKEN}
    >
      <input type="hidden" name="_subject" value="Nouvelle inscription: alerte sorties L'École du Bélier" />
      {!CONTACT_FORM_CAPTCHA_ENABLED && <input type="hidden" name="_captcha" value="false" />}
      <input type="hidden" name="_next" value={CONTACT_FORM_REDIRECT_URL} />
      <input type="hidden" name="_url" value={formPageUrl} />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="source" value="site-lecoledubelier" />
      <input
        type="text"
        name="_honey"
        class="contact-honeypot"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />

      <label for="alert-email" class="alert-label">Votre adresse email</label>
      <div class="alert-controls">
        <input
          id="alert-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="Votre email"
          class="alert-input"
        />
        <button type="submit" class="alert-submit" disabled>Activer l'alerte</button>
      </div>
    </form>

    <p class="contact-note">
      Service d'alerte opéré via {CONTACT_FORM_PROVIDER}. Email transmis uniquement pour prévenir des sorties.
      Aucune vente en ligne pour le moment.
    </p>
  </div>
</section>

<script>
  import '../scripts/contact.ts';
</script>
