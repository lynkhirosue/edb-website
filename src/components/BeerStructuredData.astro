---
import { loadBeers, loadCatalog } from '../utils/data-loader';
import { buildBeerDisplayItems } from '../utils/catalog-display';
import { safeJsonStringify } from '../utils/json-serialization';

export interface Props {
  title?: string;
}

const beers = buildBeerDisplayItems(await loadBeers(), await loadCatalog());
const { title = "L'École du Bélier" } = Astro.props;
const baseSiteUrl = Astro.site?.toString() ?? 'https://lecoledubelier.beer';
const currentUrl = new URL(Astro.url.pathname, baseSiteUrl).toString();

/**
 * Mapping availability locale → Schema.org
 * Aligné avec le contrat public-catalog.json (Sprint 6.4)
 *
 *  BreweryManager          catalog-mapper        Schema.org
 *  ─────────────────────   ──────────────────    ──────────────────────────
 *  in_stock (any level)  → 'available'         → InStock
 *  out_of_stock+coming   → 'coming_soon'       → PreOrder
 *  out_of_stock          → 'sold_out'           → OutOfStock
 */
const availabilityMap: Record<string, string> = {
  available: 'https://schema.org/InStock',
  coming_soon: 'https://schema.org/PreOrder',
  sold_out: 'https://schema.org/OutOfStock'
};

const beerProducts = beers.map((beer) => {
  const additionalProperties: Record<string, string>[] = [];

  if (beer.abv) {
    additionalProperties.push({
      '@type': 'PropertyValue',
      name: 'ABV',
      value: beer.abv
    });
  }

  if (beer.flavorProfile.length > 0) {
    additionalProperties.push({
      '@type': 'PropertyValue',
      name: 'Profil gustatif',
      value: beer.flavorProfile.join(', ')
    });
  }

  // Ajouter la saison si présente
  if (beer.season) {
    additionalProperties.push({
      '@type': 'PropertyValue',
      name: 'Saison',
      value: beer.season
    });
  }

  const product: Record<string, unknown> = {
    '@type': 'Product',
    name: beer.name,
    brand: {
      '@type': 'Brand',
      name: "L'École du Bélier"
    },
    isFamilyFriendly: false,
    additionalProperty: additionalProperties,
    offers: {
      '@type': 'Offer',
      priceCurrency: 'EUR',
      availability: availabilityMap[beer.availability] ?? 'https://schema.org/OutOfStock',
      url: new URL(`/bieres/${beer.id}`, baseSiteUrl).toString()
    }
  };

  if (beer.description) {
    product.description = beer.description;
  }

  if (beer.type) {
    product.category = beer.type;
  }

  // Ajouter l'image si disponible
  if (beer.image) {
    product.image = /^https:\/\//i.test(beer.image)
      ? beer.image
      : new URL(beer.image, baseSiteUrl).toString();
  }

  // Ajouter les tags comme keywords
  if (beer.tags.length > 0) {
    product.keywords = beer.tags.join(', ');
  }

  return product;
});

const organizationData = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: "L'École du Bélier",
  url: baseSiteUrl,
  logo: new URL('/logo-white-nobg.png', baseSiteUrl).toString(),
  description: 'Femto-brasserie en Nouvelle-Aquitaine. Bières brassées en petits lots.',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'FR',
    addressRegion: 'Nouvelle-Aquitaine',
    postalCode: '33530',
    addressLocality: 'Bassens'
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    url: new URL('/#contact', baseSiteUrl).toString(),
    availableLanguage: ['French']
  }
};

const productsData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: beerProducts.map((product, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: product
  }))
};

const localBusinessData = {
  '@context': 'https://schema.org',
  '@type': 'Brewery',
  '@id': baseSiteUrl,
  name: "L'École du Bélier",
  image: new URL('/og-image.jpg', baseSiteUrl).toString(),
  description: 'Femto-brasserie produisant des bières en petits lots en Nouvelle-Aquitaine.',
  url: baseSiteUrl,
  servesCuisine: 'Beer',
  priceRange: '$$',
  areaServed: 'Nouvelle-Aquitaine',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'FR',
    addressRegion: 'Nouvelle-Aquitaine',
    postalCode: '33530',
    addressLocality: 'Bassens'
  }
};

const webSiteData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: "L'École du Bélier",
  url: baseSiteUrl,
  inLanguage: 'fr-FR',
  publisher: {
    '@type': 'Organization',
    name: "L'École du Bélier"
  }
};

const webPageData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': currentUrl,
  url: currentUrl,
  name: title,
  inLanguage: 'fr-FR',
  isFamilyFriendly: false
};

const organizationJson = safeJsonStringify(organizationData);
const productsJson = safeJsonStringify(productsData);
const localBusinessJson = safeJsonStringify(localBusinessData);
const webSiteJson = safeJsonStringify(webSiteData);
const webPageJson = safeJsonStringify(webPageData);
---

<script type="application/ld+json" set:html={organizationJson} />
<script type="application/ld+json" set:html={productsJson} />
<script type="application/ld+json" set:html={localBusinessJson} />
<script type="application/ld+json" set:html={webSiteJson} />
<script type="application/ld+json" set:html={webPageJson} />
